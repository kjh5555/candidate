{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "ingest": "tsx src/ingest/index.ts",
    "ingest:all": "tsx src/ingest/index.ts all 22",
    "ingest:legislators": "tsx src/ingest/index.ts legislators 22",
    "ingest:bills": "tsx src/ingest/index.ts bills 22",
    "ingest:votes": "tsx src/ingest/index.ts votes 22",
    "ingest:districts": "tsx src/ingest/index.ts districts",
    "ingest:resolve": "tsx src/ingest/index.ts resolve 22"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@repo/shared": "workspace:*",
    "fastify": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
