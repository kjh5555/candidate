# PostgreSQL connection (Railway auto-injects this when Postgres plugin is added)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# 열린국회정보 OpenAPI key — register at https://open.assembly.go.kr
ASSEMBLY_API_KEY=""

# Kakao Local REST API key — register at https://developers.kakao.com
KAKAO_REST_API_KEY=""

# 국회도서관 지방의정포털 key — register at https://clik.nanet.go.kr
CLIK_API_KEY=""

# 중앙선거관리위원회 / data.go.kr 일반인증키 — register at https://data.go.kr
# Used for 제9회 전국동시지방선거 candidate ingestion (PofelcddInfoInqireService)
NEC_API_KEY=""

# Optional: path to a CSV of provincial council members for local seeding
PROVINCIAL_CSV_PATH=""

# 열린재정포털 (openfiscaldata.go.kr) API key — register at https://www.openfiscaldata.go.kr
FISCAL_API_KEY=""

# 지방재정365 (lofin365.go.kr) API key
LOFIN_API_KEY=""

# Fastify
PORT="3001"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
