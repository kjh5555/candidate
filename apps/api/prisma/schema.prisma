generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LegislatorLevel {
  NATIONAL // 국회의원
  PROVINCIAL // 광역의원 (시·도의회)
  BASIC // 기초의원 (시·군·구의회)
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum VoteResult {
  YES
  NO
  ABSTAIN
  ABSENT
}

enum BillResult {
  PASSED
  PASSED_AMENDED
  REJECTED
  WITHDRAWN
  SUPERSEDED
  PENDING
}

enum ProposerRole {
  PRIMARY
  CO
}

enum DistrictLevel {
  NATIONAL
  PROVINCIAL
}

enum CandidatePositionType {
  GOVERNOR // 시·도지사
  MAYOR // 시장·군수·구청장
}

enum CandidateStatus {
  REGISTERED // 등록
  WITHDRAWN // 사퇴
  CANCELLED // 무효/취소
  UNKNOWN
}

enum BudgetLevel {
  NATIONAL // 중앙정부
  METROPOLITAN // 광역 (시·도)
}

enum SettlementLevel {
  METROPOLITAN // 광역 단체 (시·도본청)
  BASIC // 기초 단체 (시·군·구)
}

model ElectoralDistrict {
  id          String        @id @default(cuid())
  level       DistrictLevel
  name        String
  sido        String?
  sigungu     String?
  sggCode     String?
  assemblyAge Int
  geojson     Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  legislators                Legislator[]
  districtMappingsNational   DistrictMapping[] @relation("NationalDistrict")
  districtMappingsProvincial DistrictMapping[] @relation("ProvincialDistrict")

  @@unique([level, name, assemblyAge])
  @@index([level])
  @@index([sggCode])
  @@index([sido])
}

model HangjeongDong {
  admCd2       String   @id
  name         String
  sido         String
  sigungu      String
  eupmyeondong String
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  districtMappings DistrictMapping[]

  @@index([sido])
  @@index([sigungu])
}

model DistrictMapping {
  id                   String             @id @default(cuid())
  hangjeongDongCode    String
  hangjeongDong        HangjeongDong      @relation(fields: [hangjeongDongCode], references: [admCd2])
  nationalDistrictId   String?
  nationalDistrict     ElectoralDistrict? @relation("NationalDistrict", fields: [nationalDistrictId], references: [id])
  provincialDistrictId String?
  provincialDistrict   ElectoralDistrict? @relation("ProvincialDistrict", fields: [provincialDistrictId], references: [id])
  assemblyAge          Int
  source               String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([hangjeongDongCode, assemblyAge])
  @@index([nationalDistrictId])
  @@index([provincialDistrictId])
}

model Legislator {
  id                    String             @id
  level                 LegislatorLevel
  name                  String
  party                 String?
  gender                Gender             @default(UNKNOWN)
  birthDate             String?
  electoralDistrictId   String?
  electoralDistrict     ElectoralDistrict? @relation(fields: [electoralDistrictId], references: [id])
  electoralDistrictName String?
  assemblyAge           Int?
  termCount             String?
  committee             String?
  phoneNumber           String?
  email                 String?
  homepage              String?
  officeAddress         String?
  titleDescription      String?
  memo                  String?
  photoUrl              String?
  councilName           String?
  region                String?
  rawSourceJson         Json?
  lastSyncedAt          DateTime?

  // NEC 후보자 ID (for cross-referencing info.nec.go.kr disclosures)
  huboid String?

  // 공직 후보자 공개 정보 (출마 시점 disclosure)
  disclosureElectionId   String? // e.g. "0020240410" or "0020220601"
  hasCriminalRecord      Boolean?  @default(false)
  criminalRecordPdfUrl   String?
  hasAssetDisclosure     Boolean?  @default(false)
  assetDisclosurePdfUrl  String?
  hasMilitaryRecord      Boolean?  @default(false)
  militaryRecordPdfUrl   String?
  hasTaxRecord           Boolean?  @default(false)
  taxRecordPdfUrl        String?
  backgroundLastSyncedAt DateTime?

  // 재산공개 (공직자윤리위원회 정기공개 — opengirok / newstapa 정제 데이터)
  assetTotalManwon       BigInt?   // 재산 총액 (만원)
  assetRealEstateManwon  BigInt?   // 부동산 (만원)
  assetSecuritiesManwon  BigInt?   // 증권 (만원)
  assetCashManwon        BigInt?   // 예금 (만원)
  assetDebtManwon        BigInt?   // 채무 (음수, 만원)
  assetReportYear        Int?      // 신고 연도 (e.g. 2025)
  assetSourceUrl         String?   // 출처 URL
  assetSourceName        String?   // "opengirok", "newstapa", "peti.go.kr"
  assetLastSyncedAt      DateTime?

  // 병역 (military service) — 행안부 관보 공직자 병역사항 공개 (data.go.kr 15110207)
  militaryStatus         String?   // e.g. "복무를 마침", "복무 사항 없음", "미필", "현역"
  militaryRank           String?   // e.g. "병장", "중사"
  militaryEnteredAt      String?   // YYYY-MM-DD or YYYYMMDD
  militaryDischargedAt   String?
  militaryReason         String?   // 면제/면접 사유
  militaryReportYear     Int?      // 관보 공개 연도
  militarySourceUrl      String?
  militaryLastSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billProposers BillProposer[]
  votes         Vote[]
  controversyTopics ControversyTopic[]
  newsArticles      NewsArticle[]

  @@index([level])
  @@index([party])
  @@index([name])
  @@index([electoralDistrictId])
  @@index([assemblyAge])
  @@index([huboid])
}

// ─── Controversy / News (논란·해명) ────────────────────────────
//
// 의원별 자동수집된 뉴스 기사 + 토픽 클러스터. 큐레이션 X. 사용자 투표 X.
// Google News RSS로 의원 이름 검색 → 본문 추출 → 휴리스틱(또는 LLM) 분류 →
// 신뢰도 점수 산출. 점수는 출처 시그널 집계로 산출(투명).

model ControversyTopic {
  id           String     @id @default(cuid())
  legislatorId String
  legislator   Legislator @relation(fields: [legislatorId], references: [id], onDelete: Cascade)
  title        String     // 토픽 제목 (휴리스틱 또는 LLM 산출)
  summary      String?    // 중립 요약 (LLM 있을 때만)
  category     String?    // "발언" | "정책" | "사법" | "기타" 등
  credibility  Int?       // 0-100 신뢰도 점수
  signals      Json?      // 점수 산출 시그널 원본 (투명성)
  firstSeenAt  DateTime   @default(now())
  lastSyncedAt DateTime   @default(now())
  articles     NewsArticle[]

  @@index([legislatorId, lastSyncedAt])
  @@index([legislatorId, credibility])
}

model NewsArticle {
  id               String            @id @default(cuid())
  topicId          String?
  topic            ControversyTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  legislatorId     String
  legislator       Legislator        @relation(fields: [legislatorId], references: [id], onDelete: Cascade)
  url              String            @unique
  source           String            // 언론사명
  title            String
  excerpt          String?           // Readability 추출 본문 요약 (또는 LLM 요약)
  publishedAt      DateTime?
  stance           String?           // "claim" | "explanation" | "neutral"
  hasPrimarySource Boolean?          // 1차 출처 인용 여부
  hasCorrection    Boolean?          // 정정/반박 표현 존재
  fetchedAt        DateTime          @default(now())

  @@index([legislatorId, publishedAt])
  @@index([topicId])
}

model Bill {
  id                  String      @id
  billNo              String
  name                String
  proposerText        String?
  primaryProposerName String?
  coProposerNamesRaw  String?
  proposedDate        DateTime?
  committee           String?
  result              BillResult?
  linkUrl             String?
  assemblyAge         Int?
  rawSourceJson       Json?
  proposerMatchStatus String?
  lastSyncedAt        DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // ── AI 요약 (Gemini grounding 기반 — 온디맨드 생성·캐시) ──
  aiSummary        String?   @db.Text // 1-3 문단 중립 요약
  aiChanges        String?   @db.Text // 개정안의 경우 변경점 (해당없으면 null)
  aiSourceSnippets Json? // Gemini grounding sources (URL 리스트)
  aiGeneratedAt    DateTime?
  aiModel          String? // 사용된 모델명 (예: "gemini-2.5-flash")

  proposers BillProposer[]
  votes     Vote[]

  @@index([assemblyAge])
  @@index([primaryProposerName])
  @@index([proposedDate])
  @@index([result])
  @@index([committee])
}

model BillProposer {
  id              String       @id @default(cuid())
  billId          String
  bill            Bill         @relation(fields: [billId], references: [id])
  legislatorId    String
  legislator      Legislator   @relation(fields: [legislatorId], references: [id])
  role            ProposerRole
  matchConfidence Float        @default(1.0)
  createdAt       DateTime     @default(now())

  @@unique([billId, legislatorId, role])
  @@index([billId])
  @@index([legislatorId])
  @@index([role])
}

model Vote {
  id           String     @id @default(cuid())
  billNo       String
  billName     String?
  billId       String?
  bill         Bill?      @relation(fields: [billId], references: [id])
  legislatorId String
  legislator   Legislator @relation(fields: [legislatorId], references: [id])
  result       VoteResult
  voteDate     DateTime
  assemblyAge  Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([billNo, legislatorId, voteDate])
  @@index([legislatorId])
  @@index([billId])
  @@index([voteDate])
  @@index([result])
  @@index([assemblyAge])
}

model Candidate {
  id            String                @id // huboid from NEC API
  electionId    String // "20260603"
  positionType  CandidatePositionType
  name          String
  hanjaName     String?
  party         String?
  gender        String?
  birthDate     String? // "YYYY-MM-DD"
  age           Int?
  occupation    String?
  education     String?
  career1       String?
  career2       String?
  address       String?
  sido          String? // sdName
  wiwName       String? // 시·군·구 (null for GOVERNOR)
  districtName  String? // sggName
  status        CandidateStatus       @default(UNKNOWN)
  registeredAt  DateTime?
  rawSourceJson Json?
  lastSyncedAt  DateTime?

  // Background data — PDF references and presence flags
  hasCriminalRecord     Boolean? @default(false)
  criminalRecordPdfUrl  String?
  hasAssetDisclosure    Boolean? @default(false)
  assetDisclosurePdfUrl String?
  hasMilitaryRecord     Boolean? @default(false)
  militaryRecordPdfUrl  String?
  hasTaxRecord          Boolean? @default(false)
  taxRecordPdfUrl       String?

  // Free-form summary fields parsed if available
  criminalRecordCount  Int? // from 통합검색 if present
  assetTotalManwon     BigInt? // 재산 (만원)
  militaryStatus       String? // 병역 상태
  taxPaidManwon        BigInt? // 납세액 (만원)
  taxOutstandingManwon BigInt? // 체납액 (만원)

  backgroundLastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pledges CandidatePledge[]

  @@index([electionId, positionType])
  @@index([sido])
  @@index([wiwName])
  @@index([party])
}

model CandidatePledge {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  ord         Int // 1..N
  category    String?
  title       String
  content     String?
  createdAt   DateTime  @default(now())

  @@unique([candidateId, ord])
  @@index([candidateId])
}

// ─── Budget (예산 정보) ─────────────────────────────────────────
//
// Hierarchical line items.
//
// NATIONAL (기획재정부 세부사업 예산편성, data.go.kr 15076058):
//   분야 (field) → 부문 (sector) → 프로그램 (program) → 세부사업 (subProject)
//
// METROPOLITAN (지방재정365 기능별 단체별 세출, data.go.kr 15058011):
//   17 시·도 × 14 분야. Typically only field-level granularity; sector/program/
//   subProject may be null.

model BudgetCategory {
  id         String      @id @default(cuid())
  level      BudgetLevel
  fiscalYear Int
  ministry   String? // 부처 — NATIONAL only
  sido       String? // 시·도 — METROPOLITAN only
  field      String // 분야
  sector     String? // 부문
  program    String? // 프로그램
  subProject String? // 세부사업
  amount     BigInt // 예산액 (원)
  createdAt  DateTime    @default(now())

  @@index([level, fiscalYear])
  @@index([ministry])
  @@index([sido])
  @@index([field])
}

model BudgetSummary {
  id          String      @id @default(cuid())
  level       BudgetLevel
  fiscalYear  Int
  groupKey    String // 'ministry' | 'field' | 'sido' | 'ministry-field' | 'sido-field'
  groupValue  String // actual value, e.g. "교육부" or "보건복지" or "서울특별시|보건"
  totalAmount BigInt
  createdAt   DateTime    @default(now())

  @@unique([level, fiscalYear, groupKey, groupValue])
  @@index([level, fiscalYear])
  @@index([groupKey])
}

// ─── Budget Settlement (세출결산 — 실제 지출) ──────────────────────
//
// Source: 지방재정365 (lofin365.go.kr) — endpoint ABIFB.
// Distinct from BudgetCategory because semantics differ:
//   - BudgetCategory = 예산편성 (planned / appropriation)
//   - BudgetSettlement = 세출결산 (actual expenditure)
//
// Includes BOTH 광역 (시·도본청) AND 기초 (시·군·구) data.

model BudgetSettlement {
  id         String          @id @default(cuid())
  fiscalYear Int
  level      SettlementLevel
  sido       String // 정식 명칭 (e.g. "서울특별시", "경기도")
  unitCode   String // laf_cd
  unitName   String // laf_hg_nm (e.g. "서울본청", "서울종로구")
  field      String // 분야
  fieldCode  String?
  sector     String? // 부문
  sectorCode String?
  amount     BigInt // 세출결산액 (원)
  rgstrDt    DateTime?
  createdAt  DateTime        @default(now())

  // GGNSE 구조별 breakdown — same key (fiscalYear, level, unitCode, field).
  // NOTE: field names use "Manwon" suffix for codebase consistency, but values
  // are stored in 원 (won) as BigInt — matching the raw lofin365 GGNSE units.
  policyBizManwon       BigInt? // 정책사업비 (원)
  financeActivityManwon BigInt? // 재무활동비 (원)
  adminOperManwon       BigInt? // 행정운영경비 (원)

  @@index([fiscalYear, level])
  @@index([sido])
  @@index([unitCode])
  @@index([field])
}

// ─── Settlement Report (결산서 원본 PDF) ────────────────────────
//
// Source: 지방재정365 (lofin365.go.kr) — endpoint SETLK.
// One row per (fiscalYear × unit) with the official 결산서 PDF link.

model SettlementReport {
  id         String   @id @default(cuid())
  fiscalYear Int
  sido       String // 정식 명칭
  unitCode   String
  unitName   String // 정규화된 이름 (e.g. "여주시")
  reportUrl  String
  reportName String? // "결산서" etc
  createdAt  DateTime @default(now())

  @@unique([fiscalYear, unitCode])
  @@index([sido])
  @@index([fiscalYear])
}

model SettlementSummary {
  id          String          @id @default(cuid())
  fiscalYear  Int
  level       SettlementLevel
  groupKey    String // "sido" | "unit" | "field" | "sido-field" | "unit-field"
  groupValue  String
  totalAmount BigInt
  createdAt   DateTime        @default(now())

  @@unique([fiscalYear, level, groupKey, groupValue])
  @@index([fiscalYear, level])
}

// ─── CLIK 회의록·의안정보 (국회도서관 지방의정포털) ───────────────
//
// Source: clik.nanet.go.kr OpenAPI
//   - /openapi/minutes.do — 회의록
//   - /openapi/bill.do    — 의안정보 (조례안·건의안 등)
//
// 광역의회·기초의회 의원의 의정활동 (조례안 발의, 본회의·상임위 회의록)
// 데이터를 의회명(`rasmblyNm`)을 키로 보관한다. 의원별 정확 매칭은 어렵지만
// 의회 단위로 묶어 의원 상세 페이지에서 보여준다.

model CouncilMinutes {
  id            String   @id @default(cuid())
  docId         String   @unique
  rasmblyId     String
  rasmblyNm     String
  sesn          String?
  mtgDe         String? // YYYYMMDD
  numpr         String?
  mitsOdr       String?
  mtgNm         String?
  viewUrl       String?
  rawSourceJson Json?
  syncedAt      DateTime @default(now())

  @@index([rasmblyNm, mtgDe])
  @@index([rasmblyId, mtgDe])
}

model CouncilBill {
  id            String   @id @default(cuid())
  docId         String   @unique
  rasmblyId     String
  rasmblyNm     String?
  biKndNm       String? // 조례안, 건의안 등
  biNo          String?
  biSj          String // 안건제목
  itncDe        String? // YYYYMMDD
  numpr         String?
  propsr        String? // 제안자
  viewUrl       String?
  rawSourceJson Json?
  syncedAt      DateTime @default(now())

  @@index([rasmblyNm, itncDe])
  @@index([rasmblyId, itncDe])
}
