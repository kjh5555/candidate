{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@repo/shared": ["./packages/shared/src/index.ts"],
      "@repo/shared/*": ["./packages/shared/src/*"]
    }
  }
}
